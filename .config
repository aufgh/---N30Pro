# ============================================================
# 磊科 N30 Pro (Netis NX30 V2) ImmortalWrt 编译配置
# 芯片: MT7981B + MT7976CN + MT7531AE
# ============================================================

# === 目标平台 ===
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_netis_nx30v2=y

# === LuCI 基础 ===
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_cn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# === Argon 主题 ===
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# === 多线多拨（校园网多拨）===
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_luci-app-syncdial=y

# === 校园网防检测 (UA-Mask) ===
CONFIG_PACKAGE_uamask=y
CONFIG_PACKAGE_luci-app-uamask=y

# === 代理 ===
CONFIG_PACKAGE_luci-app-openclash=y

# === USB 与 RNDIS 支持模块 (解决 USB 供电与共享网络的基础依赖) ===
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_usbutils=y

# === 其他常用依赖 ===
CONFIG_PACKAGE_luci-app-macvlan=y
CONFIG_PACKAGE_kmod-macvlan=y

# === VPN 与远程唤醒 ===
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y

# === 通用功能 ===
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
